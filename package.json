{
 "name": "easv3",
 "private": true,
 "type": "module",
 "version": "3.0.0",
 "scripts": {
  "dev": "vite",
  "build": "vite build",
  "lint:fix": "eslint . --ext .js,.ts,.jsx,.tsx --fix",
  "lint": "eslint . --ext .js,.ts,.jsx,.tsx",
  "stylelint:fix": "stylelint '**/*.{css,scss}' --fix",
  "stylelint": "stylelint '**/*.{css,scss}'",
  "test:monitoring": "checkly test",
  "test": "vitest",
  "test:ci": "vitest run --reporter=verbose --coverage && npx playwright test",
  "test:coverage": "npm run coverage:pre-check && vitest run --coverage",
  "coverage:find-orphaned": "php scripts/coverage-extraction/generate-orphaned-templates-report.php",
  "coverage:pre-check": "npm run coverage:find-orphaned",
  "coverage:check-orphaned": "node scripts/helpers/maintain-orphaned-templates.ts check",
  "coverage:maintain-orphaned": "node scripts/helpers/maintain-orphaned-templates.ts maintain --verbose",
  "coverage:cleanup-orphaned": "node scripts/helpers/maintain-orphaned-templates.ts cleanup",
  "coverage:cleanup-orphaned:force": "node scripts/helpers/maintain-orphaned-templates.ts cleanup --no-dry-run",
  "test:ui": "vitest --ui",
  "test:watch": "vitest --watch",
  "test:global-search:unit": "vitest run testing/unit/global-search.unit.test.ts",
  "test:global-search:integration": "vitest run testing/integration/global-search.integration.test.ts",
  "test:global-search:e2e": "npx playwright test --config=playwright-global-search.config.ts",
  "test:global-search:all": "npx tsx ./scripts/test-global-search.ts",
  "typecheck": "npx tsc --noEmit --pretty",
  "typecheck:watch": "npx tsc --noEmit --watch --pretty",
  "typecheck:verbose": "npx tsc --noEmit --listFiles --extendedDiagnostics",
  "typecheck:trace": "npx tsc --noEmit --traceResolution --diagnostics",
  "test:report": "npx playwright show-report",
  "analyze:twig": "npx tsx ./testing/helpers/twig-renderer.ts",
  "analyze:twig:watch": "npx tsx watch ./testing/helpers/twig-renderer.ts",
  "archive:coverage": "npx tsx ./scripts/services/archive-coverage.ts",
  "audit:deps": "node ./scripts/helpers/package-audit.cjs",
  "audit:scss": "bash ./scripts/helpers/audit-scss-v2.sh",
  "audit:scss:old": "bash ./scripts/helpers/audit-scss.sh",
  "find:env": "node ./scripts/helpers/find-env-vars.cjs",
  "find:tests": "node ./scripts/helpers/find-tests.cjs",
  "validate": "npm run validate:packages && npm run validate:scripts",
  "validate:dependencies": "node ./scripts/services/validate-dependencies.cjs",
  "validate:packages": "node ./scripts/services/validate-packages.cjs",
  "validate:scripts": "node ./scripts/services/validate-scripts.cjs",
  "auto:screens": "node ./scripts/helpers/migrate-to-auto-screenshots.js",
  "update:imports": "node ./scripts/helpers/update-imports.ts",
  "verify:imports": "node ./scripts/helpers/verify-imports.ts"
 },
 "dependencies": {
  "@foliojs-fork/fontkit": "^1.9.2",
  "@playwright/test": "^1.57.0",
  "@popperjs/core": "^2.11.8",
  "bootstrap": "^5.3.8",
  "datatables.net-bs5": "^2.3.5",
  "datatables.net-buttons-bs5": "^3.2.5",
  "datatables.net-responsive-bs5": "^3.0.7",
  "datatables.net-scroller-bs5": "^2.4.3",
  "datatables.net-staterestore-bs5": "^1.4.3",
  "dotenv-expand": "^12.0.3",
  "jquery": "^3.7.1",
  "keyv": "^5.5.5",
  "markdown-it": "^14.1.0",
  "pdfmake": "^0.2.20",
  "pinia": "^3.0.4",
  "select2": "^4.0.13",
  "vue": "^3.5.24"
 },
 "devDependencies": {
  "@axe-core/playwright": "^4.11.0",
  "@babel/core": "^7.28.5",
  "@babel/parser": "^7.28.5",
  "@babel/plugin-transform-block-scoping": "^7.28.5",
  "@babel/types": "^7.28.5",
  "@codecov/vite-plugin": "^1.9.1",
  "@faker-js/faker": "^10.1.0",
  "@graphql-codegen/cli": "^6.1.0",
  "@nuxt/devtools": "^3.1.1",
  "@testing-library/dom": "^10.4.1",
  "@testing-library/user-event": "^14.6.1",
  "@types/bootstrap": "^5.2.10",
  "@types/color": "^4.2.0",
  "@types/fontkit": "^2.0.8",
  "@types/jquery": "^3.5.33",
  "@types/jsdom": "^27.0.0",
  "@types/node": "^24.10.3",
  "@types/select2": "^4.0.63",
  "@types/twig": "^1.12.17",
  "@vitest/browser": "^4.0.15",
  "@vitest/coverage-v8": "^4.0.15",
  "@vitest/ui": "^4.0.10",
  "@vue/test-utils": "^2.4.6",
  "axe-core": "^4.11.0",
  "canvas": "^3.2.0",
  "color": "^5.0.3",
  "dotenv": "^17.2.3",
  "dotenv-cli": "^11.0.0",
  "dotenv-linter": "^0.2.0",
  "eslint": "^9.39.1",
  "eslint-plugin-jsdoc": "^61.2.1",
  "glob": "^13.0.0",
  "jiti": "^2.6.1",
  "jsdom": "^27.2.0",
  "otpauth": "^9.4.1",
  "pino": "^10.1.0",
  "pino-pretty": "^13.1.2",
  "playwright": "^1.56.1",
  "sass": "^1.94.1",
  "stylelint": "^17.0.0",
  "stylelint-config-standard-scss": "^17.0.0",
  "tsx": "^4.20.6",
  "twig": "^1.17.1",
  "typescript": "^5.9.3",
  "typescript-eslint": "^8.47.0",
  "vite": "^6.4.1",
  "vite-plugin-symfony": "^8.2.3",
  "vitest": "^4.0.15",
  "xml2js": "^0.6.2"
 }
}
