{
 "type": "project",
 "license": "proprietary",
 "minimum-stability": "beta",
 "name": "eac/easv3",
 "description": "Symfony 6.4 web application, featuring Doctrine ORM, advanced authentication (2FA), QR code generation, Vite asset management, Twig templating, and comprehensive testing tools",
 "prefer-stable": true,
 "require": {
  "php": ">=8.2",
  "ext-ctype": "*",
  "ext-iconv": "*",
  "composer/package-versions-deprecated": "1.11.99.*",
  "doctrine/annotations": "2.0.2",
  "doctrine/cache": "2.2.0",
  "doctrine/common": "3.5.0",
  "doctrine/dbal": "4.2.3",
  "doctrine/doctrine-bundle": "2.14",
  "doctrine/doctrine-migrations-bundle": "3.4.2",
  "doctrine/migrations": "3.9.0",
  "doctrine/orm": "3.3.2",
  "dompdf/dompdf": "^3.1",
  "endroid/qr-code": "^6.0",
  "gedmo/doctrine-extensions": "3.20.0",
  "knplabs/knp-snappy-bundle": "^1.10",
  "lcobucci/clock": "3.2.*",
  "nesbot/carbon": "3.9.0",
  "nikic/php-parser": "5.4.0",
  "omines/datatables-bundle": "^0.10.1",
  "pentatrion/vite-bundle": "8.0.2",
  "php-http/guzzle7-adapter": "^1.1",
  "phpdocumentor/reflection-docblock": "5.6.2",
  "phpstan/phpdoc-parser": "2.1.0",
  "predis/predis": "^3.2",
  "rybakit/twig-deferred-extension": "^3.0",
  "scheb/2fa-email": "7.10.0",
  "scheb/2fa-totp": "7.10.0",
  "scheb/2fa-trusted-device": "7.10.0",
  "spatie/ssh": "1.13.0",
  "squirrelphp/twig-php-syntax": "1.10",
  "stof/doctrine-extensions-bundle": "1.14.0",
  "symfony/asset": "6.4.*",
  "symfony/cache": "6.4.*",
  "symfony/cache-contracts": "3.5.1",
  "symfony/config": "6.4.*",
  "symfony/console": "6.4.*",
  "symfony/dependency-injection": "6.4.*",
  "symfony/doctrine-bridge": "6.4.*",
  "symfony/dotenv": "6.4.*",
  "symfony/expression-language": "6.4.*",
  "symfony/finder": "6.4.*",
  "symfony/flex": "1.22.0",
  "symfony/form": "6.4.*",
  "symfony/framework-bundle": "6.4.*",
  "symfony/http-client": "^6.4",
  "symfony/http-client-contracts": "3.5.2",
  "symfony/http-foundation": "6.4.*",
  "symfony/http-kernel": "6.4.*",
  "symfony/intl": "6.4.*",
  "symfony/mailer": "6.4.*",
  "symfony/mailgun-mailer": "^6.4",
  "symfony/mime": "6.4.*",
  "symfony/notifier": "6.4.*",
  "symfony/process": "6.4.*",
  "symfony/property-access": "6.4.*",
  "symfony/property-info": "6.4.*",
  "symfony/proxy-manager-bridge": "6.4.*",
  "symfony/rate-limiter": "6.4.*",
  "symfony/routing": "6.4.*",
  "symfony/runtime": "6.4.*",
  "symfony/security-bundle": "6.4.*",
  "symfony/security-core": "6.4.*",
  "symfony/security-http": "6.4.*",
  "symfony/serializer": "6.4.*",
  "symfony/service-contracts": "3.5.1",
  "symfony/string": "6.4.*",
  "symfony/translation": "6.4.*",
  "symfony/twig-bridge": "6.4.*",
  "symfony/twig-bundle": "6.4.*",
  "symfony/validator": "6.4.*",
  "symfony/var-dumper": "6.4.*",
  "symfony/var-exporter": "6.4.*",
  "symfony/web-link": "6.4.*",
  "symfony/yaml": "6.4.*",
  "symfonycasts/reset-password-bundle": "1.23.1",
  "twig/cache-extra": "3.20.0",
  "twig/cssinliner-extra": "3.20.0",
  "twig/extra-bundle": "3.20.0",
  "twig/intl-extra": "3.20.0",
  "twig/string-extra": "3.20.0",
  "twig/twig": "3.20.0"
 },
 "require-dev": {
  "dg/bypass-finals": "^1.6",
  "doctrine/doctrine-fixtures-bundle": "^3.6",
  "fakerphp/faker": "^1.24",
  "friendsofphp/php-cs-fixer": "^3.20",
  "infection/infection": "^0.30.3",
  "joshtronic/php-loremipsum": "^2.1",
  "mikey179/vfsstream": "^1.6",
  "mockery/mockery": "^1.5",
  "phpstan/phpstan": "^1.12",
  "phpunit/phpunit": "^11.5",
  "rector/rector": "^1.2.10",
  "robiningelbrecht/phpunit-pretty-print": "^1.4",
  "symfony/browser-kit": "6.4.19",
  "symfony/css-selector": "6.4.13",
  "symfony/debug-bundle": "6.4.13",
  "symfony/maker-bundle": "^1.64",
  "symfony/panther": "^2.1",
  "symfony/phpunit-bridge": "^7.0",
  "symfony/stopwatch": "6.4.19",
  "symfony/web-profiler-bundle": "6.4.19",
  "zenstruck/foundry": "^2.6"
 },
 "config": {
  "allow-plugins": {
   "symfony/flex": true,
   "symfony/runtime": true,
   "infection/extension-installer": true,
   "php-http/discovery": false,
   "tbachert/spi": true,
   "endroid/installer": true
  },
  "audit": {
   "block-insecure": false
  },
  "optimize-autoloader": true,
  "preferred-install": {
   "*": "dist"
  },
  "sort-packages": true
 },
 "autoload": {
  "psr-4": {
   "App\\": "src/"
  }
 },
 "autoload-dev": {
  "psr-4": {
   "App\\Tests\\": "tests/",
   "App\\Testing\\": "testing/"
  }
 },
 "replace": {
  "symfony/polyfill-ctype": "*",
  "symfony/polyfill-iconv": "*",
  "symfony/polyfill-php72": "*"
 },
 "scripts": {
  "auto-scripts": {
   "cache:clear": "symfony-cmd",
   "assets:install %PUBLIC_DIR%": "symfony-cmd"
  },
  "phpstan": "phpstan analyse src --level=0 --memory-limit=1G --error-format=table",
  "phpstan:balanced": "phpstan analyse src --level=3 --memory-limit=3G --error-format=table --no-progress",
  "phpstan:strict": "phpstan analyse src --level=6 --memory-limit=4G --error-format=table --no-progress --xdebug",
  "phpstan:max": "phpstan analyse src --level=max --memory-limit=6G --error-format=table --no-progress --xdebug",
  "phpstan:baseline": "phpstan analyse src --level=3 --memory-limit=3G --generate-baseline",
  "phpstan:ci": "phpstan analyse src --level=0 --memory-limit=2G --error-format=github --no-progress",
  "phpstan:report": "phpstan analyse src --level=0 --memory-limit=2G --error-format=json > phpstan-report.json",
  "phpstan:fix": "phpstan analyse src --level=0 --memory-limit=2G --error-format=table | grep -A 1 'tip\\|Fix'",
  "phpstan:count": "phpstan analyse src --level=0 --memory-limit=1028M --error-format=raw | wc -l",
  "phpstan:1:count": "phpstan analyse src --level=1 --memory-limit=2G --error-format=raw | wc -l",
  "phpstan:3:count": "phpstan analyse src --level=3 --memory-limit=3G --error-format=raw --no-progress | wc -l",

  "phpstan:compare": "@php -r \"echo '\\033[1;36m📊 PHPStan Level Comparison\\033[0m\\n'; echo '\\033[1;33m▶️  Level 0: Running...\\033[0m\\n'; system('composer phpstan:count'); echo '\\033[1;33m▶️  Level 1: Running...\\033[0m\\n'; system('composer phpstan:1:count'); echo '\\033[1;33m▶️  Level 3: Running...\\033[0m\\n'; system('composer phpstan:3:count'); echo '\\033[1;32m✅ Comparison complete!\\033[0m\\n';\"",
  "phpstan:dashboard": "@php -r \"echo '\\033[1;35m🎯 PHPStan Dashboard\\033[0m\\n========================\\n'; echo '\\033[1;34mProject:\\033[0m Early Access System v3\\n'; echo '\\033[1;34mAnalyzing:\\033[0m src/ directory\\n'; echo '\\033[1;34mMemory:\\033[0m 1GB limit\\n\\n';\"; phpstan analyse src --level=0 --memory-limit=1G --error-format=table --no-progress | findstr /C:\"Found\" /C:\"[ERROR]\"",
  "phpstan:watch": "watch -n 60 'composer phpstan'",
  "phpstan:parallel": "phpstan analyse src --level=0 --memory-limit=2G --parallel",
  "phpstan:parallel:max": "phpstan analyse src --level=0 --memory-limit=2G --parallel=$(nproc)",
  "phpstan:progress": "@php -r \"echo '\\033[1;36m⚡ PHPStan with Progress\\033[0m\\n';\"; phpstan analyse src --level=0 --memory-limit=1G --error-format=table --ansi",
  "phpstan:pretty": "phpstan analyse src --level=0 --memory-limit=1G --error-format=prettyJson",
  "phpstan:visual": "@php -r \"echo '\\033[1;34m🚀 Starting PHPStan Analysis...\\033[0m\\n';\"; phpstan analyse src --level=0 --memory-limit=1G --error-format=table --ansi; @php -r \"echo '\\033[1;32m✅ Analysis complete!\\033[0m\\n';\"",
  "phpstan:clean": "phpstan analyse src --level=0 --memory-limit=1G --error-format=raw --no-progress --quiet",
  "phpstan:summary": "@php -r \"echo '\\n🔍 PHPStan Analysis Summary\\n========================\\n';\"; phpstan analyse src --level=0 --memory-limit=1G --error-format=table --no-progress | head -50",
  "phpstan:colorful": "@php -r \"echo '\\033[1;95m🎨 PHPStan Colorful Mode\\033[0m\\n';\"; phpstan analyse src --level=0 --memory-limit=1G --error-format=table --ansi --verbose",
  "phpstan:quick": "@php -r \"echo '\\033[1;92m⚡ Quick PHPStan Check\\033[0m\\n';\"; phpstan analyse src --level=0 --memory-limit=1G --error-format=raw --no-progress | head -10",
  "phpstan:stats": "@php -r \"echo '\\033[1;33m📈 PHPStan Statistics\\033[0m\\n';\"; phpstan analyse src --level=0 --memory-limit=1G --error-format=table --no-progress | findstr /C:\"Found\"",
  "phpstan:minimal": "phpstan analyse src --level=0 --memory-limit=1G --error-format=raw --quiet --no-progress",
  "rector": "rector process src --dry-run",
  "test": "phpunit",
  "test:unit": "phpunit --testsuite=unit",
  "test:integration": "phpunit --testsuite=integration",
  "test:feature": "phpunit --testsuite=feature",
  "test:coverage": "phpunit --coverage-html \"build/coverage-html\" --coverage-clover \"build/coverage-clover/clover.xml\"",
  "test:coverage-check": "phpunit --coverage-text --coverage-clover build/coverage-clover/clover.xml",
  "coverage": "phpunit --coverage-html build/coverage-html/ --coverage-clover build/coverage-clover/clover.xml",
  "generate:docs": "php scripts/artifact-generation/generate-documentation.php",
  "generate:map": "php scripts/artifact-generation/generate-twig-entity-map.php",
  "generate:methods": "php scripts/coverage-extraction/generate-method-coverage-map.php",
  "generate:relations": "php scripts/artifact-generation/generate-relationship-maps.php",
  "generate:all": "composer generate:docs && composer generate:map && composer generate:methods && composer generate:relations",
  "templates:usage": "php scripts/coverage-extraction/template-usage-mapper.php",
  "templates:classify": "php scripts/coverage-extraction/classify-templates.php",
  "extract:methods": "php scripts/coverage-extraction/extract-controller-methods.php",
  "coverage:all": "php scripts/artifact-generation/generate-relationship-maps.php && php scripts/artifact-generation/generate-documentation.php && php scripts/coverage-extraction/extract-controller-methods.php &&  php scripts/coverage-extraction/run-coverage-analysis.php",
  "coverage:max": "php scripts/artifact-generation/generate-relationship-maps.php && php scripts/artifact-generation/generate-documentation.php && php scripts/artifact-generation/generate-twig-entity-map.php && php scripts/coverage-extraction/generate-method-coverage-map.php && php scripts/coverage-extraction/template-usage-mapper.php && php scripts/coverage-extraction/classify-templates.php && php scripts/coverage-extraction/extract-controller-methods.php && php scripts/coverage-extraction/run-coverage-analysis.php",
  "coverage:check": "php scripts/coverage-extraction/run-coverage-analysis.php",
  "cs-fixer": "php-cs-fixer fix",
  "infection": "infection --threads=4",
  "docs:entity": "php scripts/artifact-generation/generate-entity-documentation.php",
  "docs:entity:dry-run": "php scripts/artifact-generation/generate-entity-documentation.php --dry-run",
  "docs:entity:force": "php scripts/artifact-generation/generate-entity-documentation.php --force",
  "docs:entity:report": "php scripts/artifact-generation/generate-entity-documentation.php --report-only",
  "docs:entity:verbose": "php scripts/artifact-generation/generate-entity-documentation.php --verbose"
 },
 "post-install-cmd": [
  "@auto-scripts",
  "Composer\\Config::disableProcessTimeout",
  "bash -lc 'find vendor -type d -name .git -prune -exec rm -rf {} + || true'"
 ],
 "post-update-cmd": [
  "@auto-scripts",
  "Composer\\Config::disableProcessTimeout",
  "bash -lc 'find vendor -type d -name .git -prune -exec rm -rf {} + || true'"
 ],
 "conflict": {
  "symfony/symfony": "*"
 },
 "extra": {
  "symfony": {
   "allow-contrib": false,
   "require": "6.4.*"
  }
 }
}
